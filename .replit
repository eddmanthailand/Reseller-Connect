modules = ["python-3.11", "postgresql-16"]
[agent]
expertMode = true
integrations = ["python_database:1.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Admin User Management"

[[workflows.workflow]]
name = "Admin User Management"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "gunicorn --bind 0.0.0.0:5000 --workers 4 --reuse-port app:app"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 34209
externalPort = 3000

[[ports]]
localPort = 35149
externalPort = 3001

[[ports]]
localPort = 38869
externalPort = 3003

[[ports]]
localPort = 40669
externalPort = 3002

[nix]
channel = "stable-25_05"
packages = ["cargo", "libiconv", "rustc"]

[deployment]
deploymentTarget = "autoscale"
run = ["gunicorn", "--bind", "0.0.0.0:5000", "--workers", "4", "--reuse-port", "app:app"]

[objectStorage]
defaultBucketID = "replit-objstore-8c6e8c60-841b-4882-8a69-88f2b490267a"
